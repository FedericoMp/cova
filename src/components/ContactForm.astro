---
import GFormBadge from "./GFormBadge.astro"
---

<div class="contact-form position-relative overflow-hidden d-flex align-items-center justify-content-center">
    <div class="container d-flex flex-column align-items-center text-white py-3 py-3 px-4 z-1 text-center">
        <GFormBadge/>
        <div class="ratio ratio-4x3">
            <iframe src="https://docs.google.com/forms/d/e/1FAIpQLSfAI8xcAXaoW2C6LP8Pz2tc9gvJAy_dky7r6C30CRGjVInpug/viewform?embedded=true">Cargando…</iframe>
        </div>
    </div>
</div>

<style>
    .contact-form {
        min-height: 35rem;
        background-size: cover;
		background-repeat: no-repeat;
		background-position: center center;
        background-image: url("https://images.unsplash.com/photo-1484807352052-23338990c6c6?q=80&w=2940&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D");
    }
    .contact-form::before {
        top: 0;
        right: 0;
        z-index: 0;
        content: '';
        width: 100%;
        height: 100%;
        position: absolute;
        background-color: #000000ba;
    }
    @media screen and (min-width: 1400px) {
        iframe {
            max-height: 80vh;
        }
        .ratio::before {
            padding-top: 65%!important;
        }
    }
</style>